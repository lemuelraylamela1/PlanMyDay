// PlanMyDay — Wedding Planner SaaS
// Multi-tenant PostgreSQL schema. Every wedding-owned model carries `weddingId`.
// UUID primary keys, createdAt/updatedAt everywhere, deletedAt where soft-deletable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  COUPLE
  ADMIN
}

enum WeddingRole {
  OWNER
  PARTNER
  PLANNER
  VIEWER
}

enum WeddingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum GuestSide {
  BRIDE
  GROOM
  BOTH
}

enum InvitationStatus {
  NOT_SENT
  SENT
  OPENED
  RESPONDED
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum SupplierStatus {
  PROSPECT
  CONTACTED
  BOOKED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum NotificationType {
  DEADLINE
  PAYMENT
  RSVP_UPDATE
  TASK_REMINDER
  COUNTDOWN
  SYSTEM
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  RSVP_SUBMIT
  PUBLISH
  INVITE
  LOGIN
}

enum WebsiteSectionType {
  HERO
  STORY
  TIMELINE
  GALLERY
  RSVP
  VENUE
  GIFT_REGISTRY
  FAQ
  COUNTDOWN
  MUSIC
  CONTACT
  CUSTOM
}

enum EmailKind {
  INVITATION
  REMINDER
  THANK_YOU
  CUSTOM
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ---------------------------------------------------------------------------
// Auth & Users
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(uuid()) @db.Uuid
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  role           Role      @default(COUPLE)
  locale         String    @default("en-PH")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  accounts       Account[]
  sessions       Session[]
  ownedWeddings  Wedding[]        @relation("WeddingOwner")
  memberships    WeddingMember[]
  authTokens     AuthToken[]
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@index([role])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Purpose-specific tokens for email verification & password reset.
model AuthToken {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  tokenHash String       @unique
  purpose   TokenPurpose
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expires])
}

// ---------------------------------------------------------------------------
// Tenant root: Wedding
// ---------------------------------------------------------------------------

model Wedding {
  id            String        @id @default(uuid()) @db.Uuid
  ownerId       String        @db.Uuid
  title         String
  subtitle      String?
  slug          String?       @unique
  partner1Name  String?
  partner2Name  String?
  date          DateTime?
  ceremonyTime  DateTime?
  receptionTime DateTime?
  venueName     String?
  venueAddress  String?
  currency      String        @default("PHP")
  timezone      String        @default("GMT")
  locale        String        @default("en-PH")
  rsvpDeadline  DateTime?
  status        WeddingStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  owner           User                    @relation("WeddingOwner", fields: [ownerId], references: [id])
  members         WeddingMember[]
  settings        WeddingSettings?
  websiteSettings WeddingWebsiteSettings?
  websiteSections WebsiteSection[]
  guestGroups     GuestGroup[]
  guests          Guest[]
  tables          SeatingTable[]
  seatAssignments SeatAssignment[]
  supplierCategories SupplierCategory[]
  suppliers       Supplier[]
  budgetCategories BudgetCategory[]
  budgetItems     BudgetItem[]
  tasks           Task[]
  timelineEvents  TimelineEvent[]
  mediaAssets     MediaAsset[]
  musicTracks     MusicTrack[]
  galleryItems    GalleryItem[]
  faqs            Faq[]
  registryItems   GiftRegistryItem[]
  emailTemplates  EmailTemplate[]
  emailSchedules  EmailSchedule[]
  emailLogs       EmailDeliveryLog[]
  invitationTokens InvitationToken[]
  rsvpResponses   RsvpResponse[]
  guestUploadToken GuestUploadToken?
  guestMediaUploads GuestMediaUpload[]
  notifications   Notification[]
  activityLogs    ActivityLog[]

  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
}

model WeddingMember {
  id        String      @id @default(uuid()) @db.Uuid
  weddingId String      @db.Uuid
  userId    String      @db.Uuid
  role      WeddingRole @default(OWNER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weddingId, userId])
  @@index([userId])
}

model WeddingSettings {
  id                String   @id @default(uuid()) @db.Uuid
  weddingId         String   @unique @db.Uuid
  dressCode         String?
  story             String?  @db.Text
  contactEmail      String?
  contactPhone      String?
  themeKey          String   @default("classic")
  primaryColor      String   @default("#b03a5b")
  secondaryColor    String   @default("#f4e6ea")
  fontHeading       String   @default("Playfair Display")
  fontBody          String   @default("Inter")
  coverImageId      String?  @db.Uuid
  backgroundMusicId String?  @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model WeddingWebsiteSettings {
  id              String   @id @default(uuid()) @db.Uuid
  weddingId       String   @unique @db.Uuid
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  customDomain    String?  @unique
  seoTitle        String?
  seoDescription  String?
  socialImageId   String?  @db.Uuid
  navigation      Json?
  passwordProtect Boolean  @default(false)
  accessPassword  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model WebsiteSection {
  id        String             @id @default(uuid()) @db.Uuid
  weddingId String             @db.Uuid
  type      WebsiteSectionType
  title     String?
  isVisible Boolean            @default(true)
  order     Int                @default(0)
  config    Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, order])
}

// ---------------------------------------------------------------------------
// Guests & Groups
// ---------------------------------------------------------------------------

model GuestGroup {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests  Guest[]

  @@index([weddingId])
  @@index([weddingId, deletedAt])
}

model Guest {
  id                  String           @id @default(uuid()) @db.Uuid
  weddingId           String           @db.Uuid
  groupId             String?          @db.Uuid
  title               String?
  firstName           String
  lastName            String
  preferredName       String?
  email               String?
  phone               String?
  side                GuestSide        @default(BOTH)
  relationship        String?
  invitationStatus    InvitationStatus @default(NOT_SENT)
  rsvpStatus          RsvpStatus       @default(PENDING)
  mealPreference      String?
  dietaryRestrictions String?
  plusOneAllowed      Boolean          @default(false)
  plusOneName         String?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  wedding         Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  group           GuestGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  seatAssignment  SeatAssignment?
  invitationToken InvitationToken?
  rsvpResponses   RsvpResponse[]

  @@index([weddingId, rsvpStatus])
  @@index([weddingId, invitationStatus])
  @@index([weddingId, side])
  @@index([weddingId, deletedAt])
  @@index([groupId])
}

// ---------------------------------------------------------------------------
// Seating
// ---------------------------------------------------------------------------

model SeatingTable {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  name      String
  capacity  Int      @default(8)
  shape     String   @default("round")
  posX      Float?
  posY      Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding     Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  assignments SeatAssignment[]

  @@index([weddingId, deletedAt])
}

model SeatAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  tableId   String   @db.Uuid
  guestId   String   @unique @db.Uuid
  seatNumber Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  table   SeatingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest   Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([tableId, seatNumber])
  @@index([weddingId])
  @@index([tableId])
}

// ---------------------------------------------------------------------------
// Suppliers
// ---------------------------------------------------------------------------

model SupplierCategory {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding   Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  suppliers Supplier[]

  @@unique([weddingId, name])
  @@index([weddingId, deletedAt])
}

model Supplier {
  id             String         @id @default(uuid()) @db.Uuid
  weddingId      String         @db.Uuid
  categoryId     String?        @db.Uuid
  company        String
  contactPerson  String?
  phone          String?
  email          String?
  website        String?
  contractAmount Decimal        @default(0) @db.Decimal(12, 2)
  downPayment    Decimal        @default(0) @db.Decimal(12, 2)
  dueDate        DateTime?
  status         SupplierStatus @default(PROSPECT)
  paymentStatus  PaymentStatus  @default(UNPAID)
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  wedding  Wedding           @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category SupplierCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  files    SupplierFile[]

  @@index([weddingId, status])
  @@index([weddingId, deletedAt])
  @@index([categoryId])
}

model SupplierFile {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @db.Uuid
  mediaId    String   @db.Uuid
  createdAt  DateTime @default(now())

  supplier Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// ---------------------------------------------------------------------------
// Budget
// ---------------------------------------------------------------------------

model BudgetCategory {
  id            String   @id @default(uuid()) @db.Uuid
  weddingId     String   @db.Uuid
  name          String
  estimatedCost Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  wedding Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items   BudgetItem[]

  @@unique([weddingId, name])
  @@index([weddingId, deletedAt])
}

model BudgetItem {
  id            String   @id @default(uuid()) @db.Uuid
  weddingId     String   @db.Uuid
  categoryId    String?  @db.Uuid
  name          String
  estimatedCost Decimal  @default(0) @db.Decimal(12, 2)
  actualCost    Decimal  @default(0) @db.Decimal(12, 2)
  paidAmount    Decimal  @default(0) @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  wedding   Wedding           @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category  BudgetCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payments  PaymentSchedule[]

  @@index([weddingId, categoryId])
  @@index([weddingId, deletedAt])
}

model PaymentSchedule {
  id           String        @id @default(uuid()) @db.Uuid
  budgetItemId String        @db.Uuid
  amount       Decimal       @default(0) @db.Decimal(12, 2)
  dueDate      DateTime?
  status       PaymentStatus @default(UNPAID)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@index([budgetItemId])
  @@index([status, dueDate])
}

// ---------------------------------------------------------------------------
// Tasks
// ---------------------------------------------------------------------------

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  weddingId      String       @db.Uuid
  title          String
  description    String?      @db.Text
  category       String?
  priority       TaskPriority @default(MEDIUM)
  deadline       DateTime?
  completed      Boolean      @default(false)
  completedAt    DateTime?
  assignedPerson String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, completed, deadline])
  @@index([weddingId, deletedAt])
}

// Global (non-tenant) reusable checklist templates.
model TaskTemplate {
  id             String       @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  category       String?
  priority       TaskPriority @default(MEDIUM)
  monthsBefore   Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([category])
}

// ---------------------------------------------------------------------------
// Timeline
// ---------------------------------------------------------------------------

model TimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  weddingId   String   @db.Uuid
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, startTime])
  @@index([weddingId, deletedAt])
}

// ---------------------------------------------------------------------------
// Media, Music, Gallery
// ---------------------------------------------------------------------------

model MediaAsset {
  id           String    @id @default(uuid()) @db.Uuid
  weddingId    String    @db.Uuid
  type         MediaType
  url          String
  thumbnailUrl String?
  fileName     String
  mimeType     String
  sizeBytes    Int       @default(0)
  category     String?
  replacesId   String?   @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  wedding       Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  supplierFiles SupplierFile[]
  galleryItems  GalleryItem[]

  @@index([weddingId, type])
  @@index([weddingId, deletedAt])
}

model MusicTrack {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  title     String
  artist    String?
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, order])
}

model GalleryItem {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  mediaId   String   @db.Uuid
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  media   MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([weddingId, order])
}

// ---------------------------------------------------------------------------
// FAQ & Gift Registry
// ---------------------------------------------------------------------------

model Faq {
  id        String   @id @default(uuid()) @db.Uuid
  weddingId String   @db.Uuid
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, order])
}

model GiftRegistryItem {
  id          String   @id @default(uuid()) @db.Uuid
  weddingId   String   @db.Uuid
  title       String
  description String?
  url         String?
  price       Decimal? @db.Decimal(12, 2)
  isReserved  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, order])
}

// ---------------------------------------------------------------------------
// Invitations & RSVP
// ---------------------------------------------------------------------------

model InvitationToken {
  id        String    @id @default(uuid()) @db.Uuid
  weddingId String    @db.Uuid
  guestId   String    @unique @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime?
  revokedAt DateTime?
  openedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guest   Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model RsvpResponse {
  id                  String     @id @default(uuid()) @db.Uuid
  weddingId           String     @db.Uuid
  guestId             String     @db.Uuid
  status              RsvpStatus @default(PENDING)
  attending           Boolean    @default(false)
  partySize           Int        @default(1)
  mealPreference      String?
  dietaryRestrictions String?
  plusOneName         String?
  message             String?    @db.Text
  submittedAt         DateTime   @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guest   Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([weddingId, status])
  @@index([guestId])
}

// ---------------------------------------------------------------------------
// Guest media uploads (public QR upload flow)
// ---------------------------------------------------------------------------

model GuestUploadToken {
  id        String    @id @default(uuid()) @db.Uuid
  weddingId String    @unique @db.Uuid
  rawToken  String    @unique
  tokenHash String    @unique
  isEnabled Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model GuestMediaUpload {
  id         String    @id @default(uuid()) @db.Uuid
  weddingId  String    @db.Uuid
  guestName  String
  message    String?   @db.Text
  fileId     String
  fileName   String
  mimeType   String
  fileSize   Int
  mediaType  MediaType
  uploadedAt DateTime  @default(now())
  deletedAt  DateTime?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId, uploadedAt])
  @@index([weddingId, deletedAt])
}

// ---------------------------------------------------------------------------
// Email system
// ---------------------------------------------------------------------------

model EmailTemplate {
  id        String    @id @default(uuid()) @db.Uuid
  weddingId String    @db.Uuid
  name      String
  kind      EmailKind @default(CUSTOM)
  subject   String
  body      String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  wedding   Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  schedules EmailSchedule[]

  @@index([weddingId, kind])
}

model EmailSchedule {
  id          String      @id @default(uuid()) @db.Uuid
  weddingId   String      @db.Uuid
  templateId  String?     @db.Uuid
  kind        EmailKind   @default(CUSTOM)
  subject     String
  body        String      @db.Text
  scheduledAt DateTime?
  status      EmailStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  wedding  Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  template EmailTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs     EmailDeliveryLog[]

  @@index([weddingId, status])
  @@index([status, scheduledAt])
}

model EmailDeliveryLog {
  id          String      @id @default(uuid()) @db.Uuid
  weddingId   String      @db.Uuid
  scheduleId  String?     @db.Uuid
  guestId     String?     @db.Uuid
  toEmail     String
  subject     String
  status      EmailStatus @default(SENT)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())

  wedding  Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  schedule EmailSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([weddingId, status])
  @@index([scheduleId])
}

// ---------------------------------------------------------------------------
// Notifications & Activity Logs
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  weddingId String           @db.Uuid
  userId    String?          @db.Uuid
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([weddingId, readAt])
  @@index([userId, readAt])
}

model ActivityLog {
  id         String         @id @default(uuid()) @db.Uuid
  weddingId  String         @db.Uuid
  userId     String?        @db.Uuid
  action     ActivityAction
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime       @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([weddingId, createdAt])
  @@index([weddingId, entityType])
}
