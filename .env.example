# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# ---------------------------------------------------------------------------
# Generate with: npx auth secret  (or) openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Base URL of the app (used for callbacks and invitation links)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Email provider (transactional). Leave blank in dev to log emails to console.
# ---------------------------------------------------------------------------
EMAIL_FROM="PlanMyDay <no-reply@planmyday.app>"
RESEND_API_KEY=""

# ---------------------------------------------------------------------------
# File storage (optional; local disk fallback used when unset)
# ---------------------------------------------------------------------------
STORAGE_DRIVER="local"
