# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# ---------------------------------------------------------------------------
# Generate with: npx auth secret  (or) openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Base URL of the app (used for callbacks and invitation links)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Email (Gmail SMTP via Nodemailer). Leave SMTP_USER/PASS blank in dev to log
# emails to the terminal.
# ---------------------------------------------------------------------------
EMAIL_FROM="PlanMyDay <your@gmail.com>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ---------------------------------------------------------------------------
# File storage (optional; local disk fallback used when unset)
# ---------------------------------------------------------------------------
STORAGE_DRIVER="local"
