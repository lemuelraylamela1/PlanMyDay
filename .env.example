# =============================================================================
# PlanMyDay — Environment template
# =============================================================================
# Copy to .env, then switch database:
#   npm run db:local      → local PostgreSQL
#   npm run db:supabase   → Supabase cloud
# =============================================================================

DB_MODE=local

# Local PostgreSQL
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"
LOCAL_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"

# Supabase (URL-encode special chars in password, e.g. ! → %21)
# DATABASE_URL = Transaction pooler (port 6543) — used by the app at runtime
# DIRECT_URL   = Session pooler (port 5432) — used by prisma db push / migrate
# If db.[REF].supabase.co fails (P1001 / IPv6), use the session pooler for DIRECT_URL.
SUPABASE_DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
SUPABASE_DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Active (set by npm run db:switch)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/planmyday?schema=public"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Email (Gmail SMTP via Nodemailer)
# ---------------------------------------------------------------------------
EMAIL_FROM="PlanMyDay <your@gmail.com>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
STORAGE_DRIVER="local"

# ---------------------------------------------------------------------------
# Guest media uploads (Google Drive — personal Gmail OAuth)
# ---------------------------------------------------------------------------
# 1. Enable Google Drive API in Google Cloud Console.
# 2. Add redirect URI (Web client): http://localhost:3000/api/google-drive/oauth/callback
# 3. npm run dev, then npm run drive:auth
# 4. Paste GOOGLE_DRIVE_REFRESH_TOKEN below.
# 5. Create a folder in Drive and set GOOGLE_DRIVE_ROOT_FOLDER_ID from its URL.
GUEST_MEDIA_STORAGE_DRIVER="google-drive"
GOOGLE_DRIVE_USER_EMAIL="planmyday.storage@gmail.com"
GOOGLE_DRIVE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""
GOOGLE_DRIVE_REFRESH_TOKEN=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
