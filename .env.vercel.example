# =============================================================================
# PlanMyDay — Vercel + Supabase (PRODUCTION)
# =============================================================================
# Do NOT copy this file into the repo as .env on Vercel.
# Paste each KEY = VALUE into:
#   Vercel Dashboard → Project → Settings → Environment Variables
# Apply to: Production (and Preview if you want PR previews to work)
# =============================================================================

# --- Required ---

#DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.nbrjkedoaqwcamdfbvat:YU,93.uCUF3@rt@@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
AUTH_SECRET=GENERATE_A_NEW_SECRET_FOR_PRODUCTION

NEXTAUTH_URL=https://your-app.vercel.app

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Optional: Google OAuth ---
# Google Cloud Console → Credentials → OAuth 2.0 Client
# Authorized redirect URI:
#   https://your-app.vercel.app/api/auth/callback/google

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Optional: Email (Resend) ---
# https://resend.com → API Keys
# Verify a domain, then set EMAIL_FROM to that domain

EMAIL_FROM=PlanMyDay <no-reply@yourdomain.com>
RESEND_API_KEY=

# --- Storage ---
# Local disk does not persist on Vercel. Keep "local" only for demos;
# uploads will not survive redeploys. Swap storage later for S3/R2/Supabase Storage.

STORAGE_DRIVER=local
