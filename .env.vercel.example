# =============================================================================
# PlanMyDay — Vercel + Supabase (PRODUCTION)
# =============================================================================
# Paste each KEY = VALUE into:
#   Vercel Dashboard → Project → Settings → Environment Variables
# Apply to: Production (and Preview if you want PR previews to work)
# =============================================================================

# --- Required ---

# Runtime (Vercel serverless): Transaction pooler — port 6543, NOT 5432.
# Supabase → Project Settings → Database → Connection string → URI → Transaction mode
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations / db push from your laptop: session pooler — port 5432 (not db.*.supabase.co if P1001)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

AUTH_SECRET=GENERATE_A_NEW_SECRET_FOR_PRODUCTION

NEXTAUTH_URL=https://your-app.vercel.app

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Required: Public RSVP website (my-wedding-rsvp) ---

# Production URL of the RSVP site (no trailing slash)
NEXT_PUBLIC_RSVP_APP_URL=https://your-rsvp-site.vercel.app

# Origin(s) allowed to call PlanMyDay /api/public/rsvp (usually same as RSVP URL)
# Multiple origins: comma-separated
RSVP_ALLOWED_ORIGIN=https://your-rsvp-site.vercel.app

# Couple notification inbox for RSVP submissions
RSVP_NOTIFICATION_EMAIL=lemuelraylameladev@gmail.com

# --- Optional: Google OAuth ---

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Optional: Email (Gmail SMTP via Nodemailer) ---

EMAIL_FROM=PlanMyDay <your@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Storage ---

STORAGE_DRIVER=local

# --- Guest media uploads (Google Drive — personal Gmail OAuth) ---

GUEST_MEDIA_STORAGE_DRIVER=google-drive
GOOGLE_DRIVE_USER_EMAIL=planmyday.storage@gmail.com
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
